{
  "name": "code-puppy-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "eas:build:ios": "eas build -p ios",
    "eas:build:android": "eas build -p android",
    "eas:build:ios:preview": "eas build -p ios --profile preview --non-interactive",
    "eas:build:android:preview": "eas build -p android --profile preview --non-interactive",
    "eas:build:ios:production": "eas build -p ios --profile production --non-interactive",
    "eas:build:android:production": "eas build -p android --profile production --non-interactive",
    "eas:submit:ios:production": "eas submit -p ios --profile production --non-interactive"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "dependencies": {
    "expo": "~54.0.31",
    "expo-constants": "~18.0.12",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "@react-native-async-storage/async-storage": "2.1.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@types/react-native": "~0.73.0",
    "eslint": "^9.35.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  }
}
